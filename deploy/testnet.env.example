# Copy to /etc/meshchain/testnet.env on the VPS (vps-setup.sh does this).

MESHCHAIN_HOME=/opt/meshchain
MESHCHAIN_BIN=/opt/meshchain/target/release/meshchain-node
MESHCHAIN_SCANNER=/opt/meshchain/target/release/meshchain-scanner
MESHCHAIN_DATA=/opt/meshchain/data/host/v0

FAUCET_PORT=8787
FAUCET_AMOUNT=100000000
FAUCET_COOLDOWN=60
CORS_ORIGIN=*

SCANNER_PORT=8788

# Optional: public domain for Caddy / docs
# MESHCHAIN_DOMAIN=faucet.example.com
