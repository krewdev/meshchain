+// ─── mesh radio ──────────────────────────────────────────────────────────────
+
+fn run_radio_cmd(dir: &Path, action: RadioAction) -> Result<()> {
+    let cfg = MeshConfig::load_or_default(dir);
+
+    match action {
+        RadioAction::Bridge { port, delay_ms, portnum } => {
+            let port = port
+                .or(cfg.radio_port.clone())
+                .unwrap_or_else(|| "".to_string());
+            let delay = delay_ms.unwrap_or(cfg.tx_delay_ms);
+            let portnum = portnum.unwrap_or(cfg.portnum);
+
+            // Locate meshtastic_bridge.py next to the mesh binary or in tools/
+            let bridge_script = locate_bridge_script();
+
+            println!("Starting MeshChain ↔ Meshtastic bridge…");
+            if port.is_empty() {
+                println!("  No port configured. Use:");
+                println!("    mesh config set --port /dev/ttyUSB0");
+                println!("    mesh radio bridge --port /dev/ttyUSB0");
+                println!("  Or run in mock mode:");
+                println!("    python3 {bridge_script} --mock");
+                return Ok(());
+            }
+            println!("  Script: {bridge_script}");
+            println!("  Port:   {port}");
+            println!("  Delay:  {delay}ms  PortNum: {portnum}");
+            println!("  Press Ctrl-C to stop.\n");
+
+            let mut child = std::process::Command::new("python3")
+                .arg(&bridge_script)
+                .arg("--port")
+                .arg(&port)
+                .arg("--tx-delay-ms")
+                .arg(delay.to_string())
+                .arg("--portnum")
+                .arg(portnum.to_string())
+                .spawn()
+                .context("Could not launch meshtastic_bridge.py — is Python 3 installed?")?;
+            child.wait()?;
+        }
+
+        RadioAction::Info { port } => {
+            let port = port
+                .or(cfg.radio_port.clone())
+                .unwrap_or_else(|| "".to_string());
+            if port.is_empty() {
+                println!("No radio port set. Configure one:");
+                println!("  mesh config set --port /dev/ttyUSB0");
+                println!("  mesh radio info --port /dev/ttyUSB0");
+                return Ok(());
+            }
+            println!("Querying Meshtastic device on {port}…");
+            // Drive the bridge in mock-info mode: send a single status query.
+            // Full native_proto query runs inside meshchain-node; delegate to it.
+            let status = Command::new("python3")
+                .arg(locate_bridge_script())
+                .arg("--port")
+                .arg(&port)
+                .arg("--portnum")
+                .arg(cfg.portnum.to_string())
+                .status();
+            match status {
+                Ok(s) if s.success() => {}
+                _ => {
+                    println!("Could not contact device on {port}.");
+                    println!("Check cable, firmware, and that meshtastic is installed:");
+                    println!("  pip install meshtastic");
+                }
+            }
+        }
+
+        RadioAction::Send { to, amount, wallet, cold, port } => {
+            // Build a signed TX the same way mesh send does, then print the
+            // radio fragment count. Actual over-the-air send requires a live bridge.
+            let port = port
+                .or(cfg.radio_port.clone())
+                .unwrap_or_else(|| "".to_string());
+            let state_path = dir.join("chain_state.json");
+            if !state_path.exists() {
+                bail!("No network state yet. Run: mesh setup && mesh demo");
+            }
+            let wallet_name = wallet.unwrap_or_else(|| cfg.default_wallet.clone());
+            let cold_name = cold.unwrap_or_else(|| cfg.default_cold_key.clone());
+            let wpath = wallet_path(dir, &wallet_name);
+            let kp = load_wallet(&wpath)?;
+            let st = ChainState::load_json(&state_path).map_err(|e| anyhow::anyhow!(e.to_string()))?;
+            let sid = short_id(&kp.public_key());
+            let acc = st
+                .account(&sid)
+                .with_context(|| "Wallet not on network yet — receive some MESH first.")?;
+            let units = parse_mesh_amount(&amount)?;
+            if units > acc.balance {
+                bail!("Insufficient balance. Have {} MESH.", fmt_mesh(acc.balance));
+            }
+            let to_sid = parse_recipient(&to).map_err(|e| anyhow::anyhow!(e))?;
+            if st.account(&to_sid).is_none() {
+                bail!("Unknown recipient {}.", mesh_name(&to_sid));
+            }
+            let body = TxBody::Transfer {
+                nonce: acc.nonce,
+                from: sid,
+                to: to_sid,
+                amount: units,
+            };
+            let need_pq = units >= st.pq_required_above;
+            let tx = if need_pq {
+                let cpath = wallet_path(dir, &cold_name);
+                let pq = load_cold(&cpath)?;
+                Tx::sign_with_pq(body, &kp, &pq).map_err(|e| anyhow::anyhow!(e.to_string()))?
+            } else {
+                Tx::sign(body, &kp).map_err(|e| anyhow::anyhow!(e.to_string()))?
+            };
+            tx.verify().map_err(|e| anyhow::anyhow!(e.to_string()))?;
+
+            let enc = tx.encode().map_err(|e| anyhow::anyhow!(e.to_string()))?;
+            let frags = fragment_bytes(session_id_from_hash(&enc), &enc)
+                .map_err(|e| anyhow::anyhow!(e.to_string()))?;
+
+            println!("Signed radio payment:");
+            println!("  To:      {} ({to})", mesh_name(&to_sid));
+            println!("  Amount:  {} MESH", fmt_mesh(units));
+            println!("  Packets: {} LoRa frames", frags.len());
+
+            if port.is_empty() {
+                println!();
+                println!("No radio port configured — TX not sent over the air.");
+                println!("To send, either:");
+                println!("  mesh config set --port /dev/ttyUSB0");
+                println!("  mesh radio send {to} {amount} --port /dev/ttyUSB0");
+                println!("Or pipe to meshtastic_bridge.py manually.");
+            } else {
+                println!("  Port:    {port}");
+                // Spawn the bridge and pipe TXHEX lines for each fragment
+                let mut child = std::process::Command::new("python3")
+                    .arg(locate_bridge_script())
+                    .arg("--port")
+                    .arg(&port)
+                    .arg("--tx-delay-ms")
+                    .arg(cfg.tx_delay_ms.to_string())
+                    .arg("--portnum")
+                    .arg(cfg.portnum.to_string())
+                    .stdin(std::process::Stdio::piped())
+                    .spawn()
+                    .context("Failed to launch meshtastic_bridge.py")?;
+
+                if let Some(stdin) = child.stdin.as_mut() {
+                    use std::io::Write;
+                    // Wait for OK
+                    for frag in &frags {
+                        let hex = hex::encode(frag);
+                        writeln!(stdin, "TXHEX {hex}")?;
+                    }
+                    writeln!(stdin, "QUIT")?;
+                }
+                child.wait()?;
+                println!("Sent {} packets over {port}.", frags.len());
+            }
+        }
+    }
+    Ok(())
+}
+
+fn locate_bridge_script() -> String {
+    // Look for tools/meshtastic_bridge.py relative to cwd, then next to the binary.
+    let candidates = [
+        "tools/meshtastic_bridge.py",
+        "../tools/meshtastic_bridge.py",
+        "meshtastic_bridge.py",
+    ];
+    for c in &candidates {
+        if std::path::Path::new(c).exists() {
+            return c.to_string();
+        }
+    }
+    "tools/meshtastic_bridge.py".to_string()
+}
+
+// ─── mesh doctor ─────────────────────────────────────────────────────────────
+
+fn run_doctor(dir: &Path) -> Result<()> {
+    println!("MeshChain Doctor — checking environment…\n");
+    let mut ok = true;
+
+    // 1. Rust toolchain
+    let rust = Command::new("rustc").arg("--version").output();
+    match rust {
+        Ok(o) if o.status.success() => {
+            println!("✅  Rust:        {}", String::from_utf8_lossy(&o.stdout).trim());
+        }
+        _ => {
+            println!("❌  Rust:        not found — install from https://rustup.rs");
+            ok = false;
+        }
+    }
+
+    // 2. Python 3
+    let py = Command::new("python3").arg("--version").output();
+    match py {
+        Ok(o) if o.status.success() => {
+            println!("✅  Python 3:    {}", String::from_utf8_lossy(&o.stdout).trim());
+        }
+        _ => {
+            println!("⚠️   Python 3:    not found — radio bridge needs it (optional for TCP-only)");
+        }
+    }
+
+    // 3. meshtastic Python library
+    let mt = Command::new("python3")
+        .args(["-c", "import meshtastic; print(meshtastic.__version__)"])
+        .output();
+    match mt {
+        Ok(o) if o.status.success() => {
+            println!(
+                "✅  meshtastic:  v{}",
+                String::from_utf8_lossy(&o.stdout).trim()
+            );
+        }
+        _ => {
+            println!("⚠️   meshtastic:  not installed — `pip install meshtastic` (radio bridge only)");
+        }
+    }
+
+    // 4. bridge script
+    let bridge = locate_bridge_script();
+    if std::path::Path::new(&bridge).exists() {
+        println!("✅  Bridge:      {bridge}");
+    } else {
+        println!("⚠️   Bridge:      {bridge} not found — run from repo root or set path");
+    }
+
+    // 5. data directory
+    println!();
+    println!("── Data directory: {} ──", dir.display());
+    let genesis = dir.join("genesis.json");
+    if genesis.exists() {
+        println!("✅  genesis.json found");
+    } else {
+        println!("⚠️   genesis.json missing — run: mesh setup  or  mesh testnet-setup");
+        ok = false;
+    }
+
+    let state = dir.join("chain_state.json");
+    if state.exists() {
+        let st = ChainState::load_json(&state).map_err(|e| anyhow::anyhow!(e.to_string()))?;
+        println!("✅  chain_state  height={} supply={} MESH", st.height, fmt_mesh(st.total_supply));
+    } else {
+        println!("⚠️   chain_state.json missing — run: mesh demo");
+    }
+
+    let keys_path = dir.join("keys");
+    if keys_path.exists() {
+        let count = fs::read_dir(&keys_path)
+            .map(|rd| rd.filter_map(|e| e.ok()).count())
+            .unwrap_or(0);
+        println!("✅  keys/        {count} file(s)");
+    } else {
+        println!("ℹ️   keys/        none yet — run: mesh new-wallet");
+    }
+
+    // 6. config
+    let cfg = MeshConfig::load_or_default(dir);
+    println!();
+    println!("── Config ──");
+    println!("   radio_port:  {}", cfg.radio_port.as_deref().unwrap_or("(not set)"));
+    println!("   tx_delay_ms: {}", cfg.tx_delay_ms);
+    println!("   portnum:     {}", cfg.portnum);
+    println!("   compression: {}", cfg.compression);
+
+    println!();
+    if ok {
+        println!("Doctor: all critical checks passed ✅");
+    } else {
+        println!("Doctor: some issues found — see ⚠️  / ❌ above.");
+    }
+    Ok(())
+}
+
+// ─── mesh monitor ─────────────────────────────────────────────────────────────
+
+fn run_monitor(dir: &Path) -> Result<()> {
+    use std::thread::sleep;
+    use std::time::Duration;
+
+    let state_path = dir.join("chain_state.json");
+    if !state_path.exists() {
+        bail!(
+            "No network data in {}.\nRun: mesh setup && mesh demo",
+            dir.display()
+        );
+    }
+
+    println!("MeshChain Monitor — refreshing every 2s. Press Ctrl-C to exit.\n");
+
+    loop {
+        // ANSI clear screen + home cursor
+        print!("\x1b[2J\x1b[H");
+
+        let st = match ChainState::load_json(&state_path) {
+            Ok(s) => s,
+            Err(e) => {
+                println!("Error reading state: {e}");
+                sleep(Duration::from_secs(2));
+                continue;
+            }
+        };
+
+        let cfg = MeshConfig::load_or_default(dir);
+        let now = std::time::SystemTime::now()
+            .duration_since(std::time::UNIX_EPOCH)
+            .map(|d| d.as_secs())
+            .unwrap_or(0);
+
+        println!("╔══════════════════════════════════════════════════╗");
+        println!("║          MeshChain Monitor                       ║");
+        println!("╚══════════════════════════════════════════════════╝");
+        println!();
+        println!("  Network    {}", st.chain_id);
+        println!("  Block      #{}", st.height);
+        println!("  Supply     {} MESH", fmt_mesh(st.total_supply));
+        println!("  Validators {}", st.validators.len());
+        println!("  PQ limit   ≥ {} MESH needs cold key", fmt_mesh(st.pq_required_above));
+        println!();
+        println!("  Radio port {}", cfg.radio_port.as_deref().unwrap_or("(not configured)"));
+        println!();
+        println!("  Accounts   {} on-chain", st.accounts.len());
+        println!();
+        println!("  Updated    {now}s unix");
+        println!();
+        println!("  Ctrl-C to exit  │  mesh help for commands");
+
+        sleep(Duration::from_secs(2));
+    }
+}
