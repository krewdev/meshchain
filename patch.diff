+/// Decode a reassembled LoRa payload and inject the message into local gossip.
+fn process_radio_payload(
+    payload: &[u8],
+    hub: &GossipHub,
+    mempool: &mut VecDeque<Tx>,
+    state: &mut ChainState,
+    finality: &mut FinalityTracker,
+    pending: &mut HashMap<String, Block>,
+    keypair: &Keypair,
+    n: usize,
+    state_path: &Path,
+) -> Result<()> {
+    use meshchain_transport::frame::decode_frame;
+    let frame = match decode_frame(payload) {
+        Ok(f) => f,
+        Err(e) => {
+            eprintln!("radio: bad frame after reassembly: {e}");
+            return Ok(());
+        }
+    };
+
+    match frame.msg_type {
+        MsgType::Tx => {
+            if let Ok(tx) = decode_tx(&frame) {
+                if tx.verify().is_ok() {
+                    let id = tx.txid_hex();
+                    if !mempool.iter().any(|t| t.txid_hex() == id) {
+                        eprintln!("radio: rx tx {id}");
+                        let _ = hub.broadcast(&GossipMsg::Tx { tx: tx.clone() });
+                        mempool.push_back(tx);
+                    }
+                }
+            }
+        }
+        MsgType::Block => {
+            if let Ok(block) = decode_block(&frame) {
+                eprintln!("radio: rx block height={}", block.header.height);
+                on_block(state, finality, pending, hub, keypair, block, n, state_path)?;
+            }
+        }
+        other => {
+            eprintln!("radio: unhandled msg_type {other:?} after reassembly");
+        }
+    }
+    Ok(())
+}
+
+/// Fragment a `Tx` into LoRa wire frames, cache for ARQ, and send each fragment.
+fn radio_send_tx(radio: &mut MeshtasticStdioTransport, hub: &mut MeshRadioHub, tx: &Tx) {
+    let frame_bytes = match encode_tx(tx) {
+        Ok(b) => b,
+        Err(e) => { eprintln!("radio tx encode error: {e}"); return; }
+    };
+    let sid = session_id_from_hash(&frame_bytes);
+    match fragment_bytes(sid, &frame_bytes) {
+        Ok(frags) => {
+            hub.cache_outbound_session(sid, frags.clone());
+            for f in &frags {
+                if let Err(e) = radio.send_raw(f) {
+                    eprintln!("radio tx send error: {e}");
+                    break;
+                }
+            }
+        }
+        Err(e) => eprintln!("radio tx frag error: {e}"),
+    }
+}
+
+/// Fragment a `Block` into LoRa wire frames, cache for ARQ, and send each fragment.
+fn radio_send_block(radio: &mut MeshtasticStdioTransport, hub: &mut MeshRadioHub, block: &Block) {
+    let frame_bytes = match encode_block(block) {
+        Ok(b) => b,
+        Err(e) => { eprintln!("radio block encode error: {e}"); return; }
+    };
+    let sid = session_id_from_hash(&frame_bytes);
+    match fragment_bytes(sid, &frame_bytes) {
+        Ok(frags) => {
+            hub.cache_outbound_session(sid, frags.clone());
+            for f in &frags {
+                if let Err(e) = radio.send_raw(f) {
+                    eprintln!("radio block send error: {e}");
+                    break;
+                }
+            }
+        }
+        Err(e) => eprintln!("radio block frag error: {e}"),
+    }
+}
