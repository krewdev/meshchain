# MeshChain validator automation — local lab profile
# Copy to local.env:  cp config/lab.env.example config/local.env

CHAIN_MODE=lab
# DATA_ROOT defaults to $MESHCHAIN_HOME/data

VALIDATOR_COUNT=3
BASE_PORT=9100
SLOT_MS=100

# debug binaries under target/debug
BUILD_PROFILE=debug
AUTO_BUILD=1

WATCHDOG_INTERVAL_SECS=15
