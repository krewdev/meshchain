# MeshChain validator automation — always-on host profile
# Usage:
#   ./mesh-validator --config config/host.env.example --release bootstrap
#   ./mesh-validator --config config/host.env.example --release start

CHAIN_MODE=host
# DATA_ROOT defaults to $MESHCHAIN_HOME/data/host

VALIDATOR_COUNT=3
BASE_PORT=9100
SLOT_MS=100

BUILD_PROFILE=release
AUTO_BUILD=1

WATCHDOG_INTERVAL_SECS=30
